{
  "name": "de-tin-marin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:ecommerce": "pnpm --filter @de-tin-marin/ecommerce dev",
    "dev:admin": "pnpm --filter @de-tin-marin/admin dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "gen:db-types": "supabase gen types typescript --project-id hmfxknqmqnmtzqviwkad --schema core,catalog,pricing,commerce,crm > packages/types/src/database.generated.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,css,md}": [
      "prettier --write"
    ]
  }
}
